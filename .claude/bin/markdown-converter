#!/usr/bin/env python3
"""
Enhanced file converter using markitdown.
Supports recursive directory search and multiple file formats.
"""

import argparse
from pathlib import Path
from markitdown import MarkItDown
import sys


SUPPORTED_FORMATS = {
    '.xlsx', '.xls',          # Excel
    '.docx', '.doc',          # Word
    '.pdf',                  # PDF
    '.pptx', '.ppt',         # PowerPoint
    '.txt',                  # Plain text
    '.md',                   # Markdown (pass-through)
    '.csv',                  # CSV
    '.tsv',                  # TSV
    '.json',                 # JSON
    '.xml',                  # XML
    '.html',                 # HTML
    '.htm',                  # HTML
    '.rtf',                  # Rich Text
}


class FileConverter:
    def __init__(self):
        self.md = MarkItDown()

    def convert_file(self, file_path: Path, output_path: Path = None) -> bool:
        """Convert a single file to markdown."""
        try:
            result = self.md.convert(str(file_path))

            if output_path is None:
                output_path = file_path.with_suffix('.md')
            else:
                output_path.parent.mkdir(parents=True, exist_ok=True)

            with open(output_path, 'w', encoding='utf-8') as f:
                f.write(result.text_content)

            print(f"✓ {file_path.relative_to(Path.cwd())}")
            return True

        except Exception as e:
            print(f"✗ {file_path.relative_to(Path.cwd())}: {e}")
            return False

    def find_files(self, root_dir: Path, recursive: bool = False) -> list[Path]:
        """Find all supported files in directory."""
        # Exclude common system/venv directories
        exclude_dirs = {
            '.venv', 'venv', 'env', '.env', '__pycache__',
            'node_modules', '.git', '.vscode', '.idea',
            'dist', 'build', 'target', 'bin', 'obj'
        }

        files = []

        if recursive:
            for ext in SUPPORTED_FORMATS:
                for file_path in root_dir.rglob(f'*{ext}'):
                    # Skip if in excluded directory
                    if any(excl in file_path.parts for excl in exclude_dirs):
                        continue
                    files.append(file_path)
        else:
            for ext in SUPPORTED_FORMATS:
                for file_path in root_dir.glob(f'*{ext}'):
                    files.append(file_path)

        return sorted(files)

    def convert_directory(self, root_dir: Path, recursive: bool = False,
                         skip_existing: bool = False) -> tuple[int, int]:
        """Convert all supported files in directory."""
        files = self.find_files(root_dir, recursive)

        if not files:
            print(f"No supported files found in {root_dir}")
            return 0, 0

        print(f"Found {len(files)} file(s) in {root_dir}\n")

        success = 0
        for file_path in files:
            md_path = file_path.with_suffix('.md')

            # Skip if markdown exists and flag is set
            if skip_existing and md_path.exists():
                print(f"⊝ {file_path.relative_to(Path.cwd())} (already converted)")
                continue

            # Skip if file is already markdown
            if file_path.suffix.lower() == '.md':
                continue

            if self.convert_file(file_path):
                success += 1

        return success, len(files)


def main():
    parser = argparse.ArgumentParser(
        description='Convert files to markdown using markitdown'
    )
    parser.add_argument(
        'path',
        nargs='?',
        type=Path,
        default=Path.cwd(),
        help='Directory or file to convert (default: current directory)'
    )
    parser.add_argument(
        '-r', '--recursive',
        action='store_true',
        help='Search recursively in subdirectories'
    )
    parser.add_argument(
        '-s', '--skip-existing',
        action='store_true',
        help='Skip files that already have .md version'
    )
    parser.add_argument(
        '--formats',
        action='store_true',
        help='List supported file formats'
    )
    parser.add_argument(
        '-o', '--output',
        type=Path,
        help='Output directory for converted files'
    )

    args = parser.parse_args()

    if args.formats:
        print("Supported file formats:")
        for fmt in sorted(SUPPORTED_FORMATS):
            print(f"  {fmt}")
        return 0

    converter = FileConverter()

    if args.path.is_file():
        success = 1 if converter.convert_file(args.path) else 0
        total = 1
    else:
        output_dir = args.output if args.output else None
        success, total = converter.convert_directory(
            args.path,
            args.recursive,
            args.skip_existing
        )

    print(f"\n✓ Done! {success}/{total} converted")
    return 0 if success == total else 1


if __name__ == '__main__':
    sys.exit(main())
